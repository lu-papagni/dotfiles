{{- /* ft: gitconfig */ -}}

[user]
  email = {{ .email }}
  name = lu-papagni

{{- if eq .chezmoi.os "linux" }}
[credential]
  helper = cache --timeout 21600
  helper = oauth
[merge]
  tool = nvimdiff
  conflictstyle = diff3
[interactive]
  diffFilter = delta --color-only
{{ end }}

[core]
  editor = {{ if ne .chezmoi.os "windows" -}} nvim --cmd 'let g:git_editor=1' {{- else -}} edit {{- end }}
  pager = {{ if ne .chezmoi.os "windows" -}} delta {{else -}} "" {{- end }}

[init]
  defaultBranch = main
[url "git@github.com"]
  insteadOf = gh
[alias]
  to-ssh = !git remote set-url origin $(git remote get-url origin | sed 's|https://github.com/|git@github.com:|')
