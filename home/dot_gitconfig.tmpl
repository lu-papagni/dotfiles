{{- /* ft: gitconfig */ -}}

[user]
  email = papagniluca4@gmail.com
  name = lu-papagni

{{- if eq .chezmoi.os "linux" }}
[credential]
  helper = cache --timeout 21600
  helper = oauth
[merge]
  tool = nvimdiff
  conflictstyle = diff3
[core]
  editor = nvim --cmd 'let g:git_editor=1'
  pager = delta
[interactive]
  diffFilter = delta --color-only
{{ end -}}

[init]
  defaultBranch = main
[url "git@github.com"]
  insteadOf = gh
[alias]
  to-ssh = !git remote set-url origin $(git remote get-url origin | sed 's|https://github.com/|git@github.com:|')
